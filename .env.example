# Copy to .env.local and fill in. NEVER commit real keys.
# These are server-side only (used by /api functions and scripts/ingest.ts).

# Anthropic API (console.anthropic.com — separate from a Claude.ai subscription)
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI embeddings (voyageai.com)
VOYAGE_API_KEY=pa-...

# Supabase (project settings → API)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
